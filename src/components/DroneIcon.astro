---
interface Props {
	size?: number;
	float?: boolean;
	class?: string;
}

const { size = 48, float = false, class: className = "" } = Astro.props;
---

<div class:list={["drone-badge", { "drone-badge--float": float }, className]} style={`--drone-size:${size}px`}>
	<span class="drone-badge__sheen" aria-hidden="true"></span>
	<img src="/agrodrone-icon.png" alt="AgroDrone Solutions" class="drone-badge__glyph" width={size} height={size} />
</div>

<style>
	.drone-badge {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: var(--drone-size);
		height: var(--drone-size);
		flex-shrink: 0;
		border-radius: 9999px;
		background:
			radial-gradient(circle at 32% 26%, rgba(255, 255, 255, 0.85), rgba(147, 197, 253, 0) 42%),
			radial-gradient(circle at 68% 78%, rgba(2, 6, 23, 0.55), rgba(2, 6, 23, 0) 55%),
			linear-gradient(155deg, #7dd3fc 0%, #3b82f6 42%, #1d4ed8 68%, #0b1d4d 100%);
		box-shadow:
			0 1px 1px rgba(255, 255, 255, 0.6) inset,
			0 -6px 10px rgba(2, 6, 23, 0.45) inset,
			0 12px 20px -8px rgba(29, 78, 216, 0.65),
			0 4px 8px rgba(2, 6, 23, 0.35);
		overflow: hidden;
	}

	.drone-badge__sheen {
		position: absolute;
		top: -35%;
		left: -20%;
		width: 75%;
		height: 65%;
		border-radius: 9999px;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.65), rgba(255, 255, 255, 0) 70%);
		filter: blur(1px);
		pointer-events: none;
	}

	.drone-badge__glyph {
		position: relative;
		width: 60%;
		height: 60%;
		object-fit: contain;
		filter: drop-shadow(0 2px 2px rgba(2, 6, 23, 0.45));
	}

	.drone-badge--float {
		animation: drone-badge-float 6s ease-in-out infinite;
	}

	@keyframes drone-badge-float {
		0%, 100% { transform: translateY(0) rotate(0deg); }
		50% { transform: translateY(-8px) rotate(4deg); }
	}

	@media (prefers-reduced-motion: reduce) {
		.drone-badge--float {
			animation: none;
		}
	}
</style>
