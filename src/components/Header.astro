---
import { SITE_TITLE, INSTAGRAM_PROFILE_URL } from '../consts';
import { getTranslation } from '../i18n';
import DroneIcon from './DroneIcon.astro';

const locale = Astro.url.searchParams.get('lang') || 'en';
const t = getTranslation(locale);
const navItems = [
	{ id: 'home', href: '#home' },
	{ id: 'services', href: '#services' },
	{ id: 'benefits', href: '#benefits' },
	{ id: 'technology', href: '#technology' },
	{ id: 'about', href: '#about' },
	{ id: 'contact', href: '#contact' },
];
---

<header class="sticky top-0 z-40 border-b border-neutral-900/10 bg-neutral-950/90 backdrop-blur">
	<nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8" aria-label="Primary navigation">
		<a href={`/?lang=${locale}`} class="flex items-center gap-3 text-white">
			<DroneIcon size={40} />
			<div>
				<p class="text-lg font-semibold">{SITE_TITLE}</p>
				<p class="text-xs uppercase tracking-[0.24em] text-neutral-400">Drone precision</p>
			</div>
		</a>
		<div class="hidden items-center gap-6 md:flex">
			{navItems.map((item) => (
				<a href={item.href} class="text-sm font-medium text-neutral-300 transition hover:text-white" data-i18n-key={`nav.${item.id}`}>{t.nav[item.id]}</a>
			))}
		</div>
		<div class="flex items-center gap-3">
			<a href={INSTAGRAM_PROFILE_URL} target="_blank" rel="noopener noreferrer" class="rounded-full border border-white/10 p-2 text-neutral-300 transition hover:text-white" aria-label="Instagram">
				<svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
					<path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm4.25 3.25a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Zm0 1.5a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm5.25-1.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z" />
				</svg>
			</a>
			<a href={`/?lang=${locale === 'pt' ? 'en' : 'pt'}`} class="rounded-full border border-blue-400/40 bg-blue-400/10 px-3 py-2 text-sm font-semibold text-blue-300 transition hover:bg-blue-400/20" data-locale-switch data-locale={locale === 'pt' ? 'en' : 'pt'}>{locale === 'pt' ? 'EN' : 'PT'}</a>
			<a href="#contact" class="hidden rounded-full bg-blue-400 px-4 py-2 text-sm font-semibold text-neutral-950 transition hover:bg-blue-300 sm:inline-flex">{t.nav.cta}</a>
		</div>
	</nav>
</header>

<script is:inline>
	const storageKey = 'agrodrone-locale';
	const switchers = document.querySelectorAll('[data-locale-switch]');
	switchers.forEach((button) => {
		button.addEventListener('click', () => {
			localStorage.setItem(storageKey, button.dataset.locale || 'en');
		});
	});

	const params = new URLSearchParams(window.location.search);
	const storedLocale = localStorage.getItem(storageKey);
	const localeParam = params.get('lang');

	if (!localeParam && storedLocale) {
		params.set('lang', storedLocale);
		window.location.search = params.toString() ? `?${params.toString()}` : '';
	} else if (localeParam && storedLocale !== localeParam) {
		localStorage.setItem(storageKey, localeParam);
	}
</script>
