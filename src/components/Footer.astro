---
import { SITE_TITLE, INSTAGRAM_PROFILE_URL, COMPANY_EMAIL, COMPANY_WHATSAPP, COMPANY_ADDRESS_US } from '../consts';
import { getTranslation } from '../i18n';
import DroneIcon from './DroneIcon.astro';

const locale = Astro.url.searchParams.get('lang') || 'en';
const t = getTranslation(locale);
const today = new Date();
---

<footer class="border-t border-neutral-200 bg-neutral-950 px-6 py-16 text-neutral-300 lg:px-8">
	<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[1.1fr_0.7fr_0.7fr]">
		<div>
			<div class="flex items-center gap-3">
				<DroneIcon size={40} />
				<p class="text-lg font-semibold text-white">{SITE_TITLE}</p>
			</div>
			<p class="mt-3 max-w-md text-base leading-7 text-neutral-400">{t.footer.description}</p>
			<a href={INSTAGRAM_PROFILE_URL} target="_blank" rel="noopener noreferrer" class="mt-5 inline-flex items-center gap-2 text-blue-300 transition hover:text-blue-200">
				<svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
					<path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm4.25 3.25a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Zm0 1.5a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm5.25-1.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z" />
				</svg>
				Instagram
			</a>
		</div>
		<div>
			<p class="text-sm font-semibold uppercase tracking-[0.24em] text-neutral-500" data-i18n-key="footer.quickLinks">{t.footer.quickLinks}</p>
			<ul class="mt-4 space-y-2">
				<li><a href="#home" class="text-neutral-300 transition hover:text-white">{t.nav.home}</a></li>
				<li><a href="#services" class="text-neutral-300 transition hover:text-white">{t.nav.services}</a></li>
				<li><a href="#technology" class="text-neutral-300 transition hover:text-white">{t.nav.technology}</a></li>
				<li><a href="#contact" class="text-neutral-300 transition hover:text-white">{t.nav.contact}</a></li>
			</ul>
		</div>
		<div>
			<p class="text-sm font-semibold uppercase tracking-[0.24em] text-neutral-500" data-i18n-key="footer.language">{t.footer.language}</p>
			<ul class="mt-4 space-y-2">
				<li><a href={`/?lang=pt`} class="text-neutral-300 transition hover:text-white">Português</a></li>
				<li><a href={`/?lang=en`} class="text-neutral-300 transition hover:text-white">English</a></li>
			</ul>
			<p class="mt-6 text-sm text-neutral-500">{COMPANY_EMAIL}</p>
			<a href={`https://wa.me/${COMPANY_WHATSAPP}`} target="_blank" rel="noopener noreferrer" class="mt-2 block text-sm text-neutral-500 transition hover:text-white">WhatsApp</a>
			<p class="mt-4 text-xs uppercase tracking-[0.2em] text-neutral-600" data-i18n-key="contact.addressLabel">{t.contact.addressLabel}</p>
			<p class="mt-1 text-sm text-neutral-500">{COMPANY_ADDRESS_US}</p>
		</div>
	</div>
	<div class="mx-auto mt-10 flex max-w-7xl flex-col gap-3 border-t border-neutral-800 pt-6 text-sm text-neutral-500 sm:flex-row sm:items-center sm:justify-between">
		<p>&copy; {today.getFullYear()} AgroDrone Solutions. {t.footer.rights}</p>
		<p>Precision. Productivity. Sustainability.</p>
	</div>
</footer>
