---
interface Props {
	t: Record<string, any>;
}

const { t } = Astro.props;
---

<section id="benefits" class="bg-neutral-950 px-6 py-24 text-white lg:px-8">
	<div class="mx-auto max-w-7xl">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-300" data-i18n-key="benefits.eyebrow">{t.benefits.eyebrow}</p>
			<h2 class="mt-3 text-3xl font-semibold sm:text-4xl" data-i18n-key="benefits.title">{t.benefits.title}</h2>
			<p class="mt-4 text-lg leading-8 text-neutral-300" data-i18n-key="benefits.description">{t.benefits.description}</p>
		</div>
		<div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{t.benefits.items.map((item: any, index: number) => (
				<article class="rounded-2xl border border-white/10 bg-white/5 p-7 shadow-lg shadow-blue-950/20">
					<div class="mb-4 h-11 w-11 rounded-full bg-blue-400/20 text-center text-xl leading-10 text-blue-300">0{index + 1}</div>
					<h3 class="text-xl font-semibold text-white" data-i18n-key={`benefits.items.${index}.title`}>{item.title}</h3>
					<p class="mt-3 text-base leading-7 text-neutral-300" data-i18n-key={`benefits.items.${index}.description`}>{item.description}</p>
				</article>
			))}
		</div>
	</div>
</section>
