---
interface Props {
	t: Record<string, any>;
}

const { t } = Astro.props;
---

<section class="bg-blue-950/95 px-6 py-24 text-white lg:px-8">
	<div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
		<div>
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-300" data-i18n-key="why.eyebrow">{t.why.eyebrow}</p>
			<h2 class="mt-3 text-3xl font-semibold sm:text-4xl" data-i18n-key="why.title">{t.why.title}</h2>
			<p class="mt-4 text-lg leading-8 text-blue-50/80" data-i18n-key="why.description">{t.why.description}</p>
		</div>
		<div class="rounded-[2rem] border border-white/10 bg-white/10 p-8 backdrop-blur">
			<ul class="space-y-4">
				{t.why.points.map((point: string, index: number) => (
					<li class="flex items-start gap-3 rounded-2xl bg-neutral-950/20 p-4">
						<span class="mt-1 text-blue-300">●</span>
						<span class="text-base leading-7 text-blue-50" data-i18n-key={`why.points.${index}`}>{point}</span>
					</li>
				))}
			</ul>
		</div>
	</div>
</section>
