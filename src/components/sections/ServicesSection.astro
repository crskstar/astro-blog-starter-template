---
interface Props {
	t: Record<string, any>;
}

const { t } = Astro.props;
---

<section id="services" class="bg-neutral-50 px-6 py-24 lg:px-8">
	<div class="mx-auto max-w-7xl">
		<div class="max-w-3xl">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-600" data-i18n-key="services.eyebrow">{t.services.eyebrow}</p>
			<h2 class="mt-3 text-3xl font-semibold text-neutral-950 sm:text-4xl" data-i18n-key="services.title">{t.services.title}</h2>
			<p class="mt-4 text-lg leading-8 text-neutral-600" data-i18n-key="services.description">{t.services.description}</p>
		</div>
		<div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-3">
			{t.services.items.map((item: any, index: number) => (
				<article class="rounded-3xl border border-neutral-200 bg-white p-7 shadow-sm transition hover:-translate-y-1 hover:shadow-xl">
					<div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-100 text-2xl text-blue-700">
						{index + 1}
					</div>
					<h3 class="text-xl font-semibold text-neutral-950" data-i18n-key={`services.items.${index}.title`}>{item.title}</h3>
					<p class="mt-3 text-base leading-7 text-neutral-600" data-i18n-key={`services.items.${index}.description`}>{item.description}</p>
				</article>
			))}
		</div>
	</div>
</section>
