---
import { INSTAGRAM_PROFILE_URL, INSTAGRAM_HANDLE } from '../../consts';

interface Props {
	t: Record<string, any>;
}

const { t } = Astro.props;
---

<section class="bg-neutral-50 px-6 py-24 lg:px-8">
	<div class="mx-auto max-w-4xl rounded-[2rem] border border-neutral-200 bg-white p-10 text-center shadow-lg shadow-neutral-200/60 sm:p-14">
		<p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-600" data-i18n-key="instagram.eyebrow">{t.instagram.eyebrow}</p>
		<h2 class="mt-3 text-3xl font-semibold text-neutral-950 sm:text-4xl" data-i18n-key="instagram.title">{t.instagram.title}</h2>
		<p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-neutral-600" data-i18n-key="instagram.description">{t.instagram.description}</p>
		<p class="mx-auto mt-4 max-w-xl rounded-2xl bg-blue-50 p-4 text-base leading-7 text-blue-700" data-i18n-key="instagram.note">{t.instagram.note}</p>
		<a href={INSTAGRAM_PROFILE_URL} target="_blank" rel="noopener noreferrer" class="mt-8 inline-flex items-center gap-2 rounded-full bg-neutral-950 px-7 py-3 font-semibold text-white transition hover:bg-neutral-800">
			<svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
				<path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm4.25 3.25a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Zm0 1.5a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm5.25-1.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z" />
			</svg>
			<span data-i18n-key="instagram.button">{t.instagram.button}</span>
			<span class="text-white/60">{INSTAGRAM_HANDLE}</span>
		</a>
	</div>
</section>
