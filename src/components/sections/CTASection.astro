---
interface Props {
	t: Record<string, any>;
}

const { t } = Astro.props;
---

<section class="bg-neutral-50 px-6 py-24 lg:px-8">
	<div class="mx-auto max-w-6xl rounded-[2rem] border border-blue-200 bg-gradient-to-r from-blue-600 to-blue-500 p-10 text-white shadow-xl shadow-blue-950/10 sm:p-14">
		<p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-100" data-i18n-key="cta.eyebrow">{t.cta.eyebrow}</p>
		<h2 class="mt-3 text-3xl font-semibold sm:text-4xl" data-i18n-key="cta.title">{t.cta.title}</h2>
		<p class="mt-4 max-w-2xl text-lg leading-8 text-blue-50/90" data-i18n-key="cta.description">{t.cta.description}</p>
		<a href="#contact" class="mt-8 inline-flex rounded-full bg-white px-6 py-3 font-semibold text-blue-700 transition hover:bg-blue-50" data-i18n-key="cta.button">{t.cta.button}</a>
	</div>
</section>
