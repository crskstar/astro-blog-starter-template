---
import { INSTAGRAM_PROFILE_URL, COMPANY_EMAIL, COMPANY_WHATSAPP, COMPANY_ADDRESS_US } from '../../consts';

interface Props {
	t: Record<string, any>;
}

const { t } = Astro.props;
---

<section id="contact" class="bg-neutral-950 px-6 py-24 text-white lg:px-8">
	<div class="mx-auto max-w-4xl">
		<div class="max-w-2xl">
			<p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-300" data-i18n-key="contact.eyebrow">{t.contact.eyebrow}</p>
			<h2 class="mt-3 text-3xl font-semibold sm:text-4xl" data-i18n-key="contact.title">{t.contact.title}</h2>
			<p class="mt-4 text-lg leading-8 text-neutral-300" data-i18n-key="contact.description">{t.contact.description}</p>
		</div>
		<div class="mt-10 grid gap-6 sm:grid-cols-2">
			<div class="rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur">
				<h3 class="text-xl font-semibold" data-i18n-key="contact.detailsTitle">{t.contact.detailsTitle}</h3>
				<ul class="mt-5 space-y-3 text-neutral-300">
					<li><span class="font-semibold text-white" data-i18n-key="contact.emailLabel">{t.contact.emailLabel}</span>: <a href={`mailto:${COMPANY_EMAIL}`} class="text-blue-300 hover:text-blue-200">{COMPANY_EMAIL}</a></li>
					<li><span class="font-semibold text-white" data-i18n-key="contact.addressLabel">{t.contact.addressLabel}</span>: <span class="text-neutral-300">{COMPANY_ADDRESS_US}</span></li>
				</ul>
				<a href={`https://wa.me/${COMPANY_WHATSAPP}`} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex rounded-full bg-blue-500 px-6 py-3 font-semibold text-white transition hover:bg-blue-400" data-i18n-key="contact.whatsapp">{t.contact.whatsapp}</a>
			</div>
			<div class="rounded-[2rem] border border-white/10 bg-white/5 p-8 backdrop-blur">
				<h3 class="text-xl font-semibold" data-i18n-key="contact.socialTitle">{t.contact.socialTitle}</h3>
				<p class="mt-3 text-base leading-7 text-neutral-300" data-i18n-key="contact.socialText">{t.contact.socialText}</p>
				<a href={INSTAGRAM_PROFILE_URL} target="_blank" rel="noopener noreferrer" class="mt-6 inline-flex rounded-full border border-white/20 px-6 py-3 font-semibold text-white transition hover:bg-white/10">Instagram</a>
			</div>
		</div>
	</div>
</section>
