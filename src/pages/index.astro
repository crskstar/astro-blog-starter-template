---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import MapSection from '../components/sections/MapSection.astro';
import BenefitsSection from '../components/sections/BenefitsSection.astro';
import ServicesSection from '../components/sections/ServicesSection.astro';
import WhySection from '../components/sections/WhySection.astro';
import TechnologySection from '../components/sections/TechnologySection.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import InstagramSection from '../components/sections/InstagramSection.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getTranslation } from '../i18n';

export const prerender = false;

const locale = Astro.url.searchParams.get('lang') || 'en';
const t = getTranslation(locale);
---

<!doctype html>
<html lang={locale === 'pt' ? 'pt-BR' : 'en'}>
	<head>
		<BaseHead title={`${SITE_TITLE} | ${t.hero.title}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<HeroSection t={t} />
			<MapSection t={t} />
			<BenefitsSection t={t} />
			<ServicesSection t={t} />
			<WhySection t={t} />
			<TechnologySection t={t} />
			<AboutSection t={t} />
			<CTASection t={t} />
			<InstagramSection t={t} />
			<ContactSection t={t} />
		</main>
		<Footer />
	</body>
</html>
